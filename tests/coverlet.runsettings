<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Include>[ShrimpCam.Api*]*,[ShrimpCam.Core*]*,[ShrimpCam.Infrastructure*]*</Include>
          <Exclude>[*.Tests*]*,[xunit.*]*,[FluentAssertions*]*,[NSubstitute*]*</Exclude>
          <ExcludeByFile>**/Program.cs,**/*.g.cs,**/Migrations/*</ExcludeByFile>
          <UseSourceLink>true</UseSourceLink>
          <SingleHit>false</SingleHit>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
