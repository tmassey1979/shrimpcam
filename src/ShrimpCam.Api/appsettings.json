{
  "ShrimpCam": {
    "Camera": {
      "Platform": "Windows",
      "Source": "Default Camera"
    },
    "Capture": {
      "IntervalMinutes": 5,
      "ActiveStartHourUtc": 6,
      "ActiveEndHourUtc": 22
    },
    "Storage": {
      "ImageRootPath": "data/images",
      "TimelapseRootPath": "data/timelapse",
      "RetentionDays": 30
    },
    "Security": {
      "HostMode": "InternetExposed"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
