{
  "ShrimpCam": {
    "Camera": {
      "Platform": "Windows",
      "Source": "Logi C270 HD WebCam"
    },
    "Capture": {
      "IntervalMinutes": 5,
      "ActiveStartHourUtc": 6,
      "ActiveEndHourUtc": 22,
      "MotionHighlightsEnabled": false,
      "MotionThreshold": 0.35,
      "MotionCooldownSeconds": 300
    },
    "Storage": {
      "DatabasePath": "data/shrimpcam.db",
      "ImageRootPath": "data/images",
      "TimelapseRootPath": "data/timelapse",
      "RetentionDays": 30
    },
    "Security": {
      "HostMode": "InternetExposed",
      "InitialAdministrator": {
        "Enabled": true,
        "UserName": "admin",
        "Password": "AdminPass1234"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1;192.168.40.96"
}
