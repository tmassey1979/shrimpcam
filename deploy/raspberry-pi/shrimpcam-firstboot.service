[Unit]
Description=Shrimp Cam first boot provisioning
DefaultDependencies=no
After=local-fs.target
Before=network-pre.target network-online.target
Wants=network-pre.target
ConditionPathExists=!/opt/shrimpcam/.firstboot-complete

[Service]
Type=oneshot
ExecStart=/usr/local/bin/shrimpcam-firstboot.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
